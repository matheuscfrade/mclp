# Git LFS tracking for large binary data files
# These files are kept in the repository (public data), but tracked via LFS
# to keep the git history manageable.

clean_data/*.parquet filter=lfs diff=lfs merge=lfs -text
clean_data/*.shp     filter=lfs diff=lfs merge=lfs -text
clean_data/*.shx     filter=lfs diff=lfs merge=lfs -text
clean_data/*.dbf     filter=lfs diff=lfs merge=lfs -text
clean_data/*.prj     filter=lfs diff=lfs merge=lfs -text
clean_data/*.cpg     filter=lfs diff=lfs merge=lfs -text

# Common binary types that may appear in the project
*.zip    filter=lfs diff=lfs merge=lfs -text
*.7z     filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
